# Odoo Configuration
ODOO_URL=https://www.babetteconcept.be/jsonrpc
ODOO_DB=babetteconcept
ODOO_USERNAME=your_odoo_username
ODOO_API_KEY=your_odoo_api_key

# Session Configuration
# Generate a secure random string (at least 32 characters) for production
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=complex_password_at_least_32_characters_long_change_this_in_production

# N8N Integration (Optional)
N8N_API_KEY=your_n8n_api_key

# OpenAI API Key (Required for AI-generated product descriptions and camera analysis)
OPENAI_API_KEY=your_openai_api_key

# Camera Monitoring
# Via the camera-proxy PowerShell script on the Windows PC (see scripts/camera-proxy.ps1)
CAMERA_1_NAME=Winkel Ingang
CAMERA_1_SNAPSHOT_URL=http://192.168.1.79:9090/snapshot/1
CAMERA_2_NAME=Camera 2
CAMERA_2_SNAPSHOT_URL=http://192.168.1.79:9090/snapshot/2
CAMERA_3_NAME=Camera 3
CAMERA_3_SNAPSHOT_URL=http://192.168.1.79:9090/snapshot/3
CAMERA_4_NAME=Camera 4
CAMERA_4_SNAPSHOT_URL=http://192.168.1.79:9090/snapshot/4

# Or direct to cameras (if network allows):
# CAMERA_1_SNAPSHOT_URL=http://172.16.1.101/cgi-bin/snapshot.cgi?channel=0
# CAMERA_1_AUTH_USER=admin
# CAMERA_1_AUTH_PASS=your_camera_password

# Analysis provider: "openai" or "yolo" (default: openai)
CAMERA_ANALYSIS_PROVIDER=openai
# YOLO_SERVICE_URL=http://localhost:8000/analyze

# Analysis interval in seconds (default: 60)
CAMERA_ANALYSIS_INTERVAL=60

# Optional: API secret for external cron triggers
# CAMERA_API_SECRET=your_random_secret

# Node Environment
NODE_ENV=development

MOLLIE_API_KEY=test_xxxx
# Optional: Access token with settlements.read scope for full settlement export
# (includes fee lines and settlement references)
# MOLLIE_ACCESS_TOKEN=access_xxxx