{
  "name": "pos-sessies",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "verify": "npm run typecheck && npm run test:run && npm run build",
    "docling:start": "podman run -d --name docling --replace -p 5001:5001 -e DOCLING_SERVE_ENABLE_UI=1 ghcr.io/docling-project/docling-serve-cpu:latest",
    "docling:stop": "podman stop docling && podman rm docling",
    "docling:logs": "podman logs -f docling",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.18",
    "@ai-sdk/react": "^4.0.38",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/xml2js": "^0.4.14",
    "ai": "^7.0.35",
    "chart.js": "^4.5.0",
    "exceljs": "^4.4.0",
    "formidable": "^3.5.4",
    "iron-session": "^8.0.4",
    "next": "^16.2.2",
    "node-fetch": "^3.3.2",
    "pdf-parse": "^2.3.0",
    "rate-limiter-flexible": "^8.1.0",
    "react": "^19.2.8",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.2.8",
    "xml2js": "^0.6.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/formidable": "^3.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.2",
    "gh-pages": "^6.3.0",
    "jsdom": "^29.1.1",
    "patch-package": "^8.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
